{
  "$schema": "https://registry.modelcontextprotocol.io/schemas/server.schema.json",
  "name": "io.github.KryptosAI/mcp-seatbelt",
  "description": "MCP runtime security proxy. Blocks dangerous AI agent tool calls with a policy engine.",
  "version": "0.5.0",
  "url": "https://github.com/KryptosAI/mcp-seatbelt",
  "repository": {
    "type": "git",
    "url": "https://github.com/KryptosAI/mcp-seatbelt.git"
  },
  "package": {
    "registry": "npm",
    "name": "@kryptosai/mcp-seatbelt",
    "version": "0.5.0"
  },
  "runtime": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "@kryptosai/mcp-seatbelt",
      "proxy"
    ]
  },
  "metadata": {
    "category": "Security",
    "tags": [
      "mcp-security",
      "mcp-proxy",
      "guardrails",
      "policy-engine",
      "dlp",
      "rbac",
      "threat-intel",
      "audit-trail"
    ]
  }
}
